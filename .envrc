# Repo-local override of the parent `~/Documents/projects/.envrc` git
# identity. The parent file pulls real-name + private email from 1Password
# (`op://Private/GitHub/{name,E-Mail}`). This repo is published publicly,
# so commits authored here use the GitHub no-reply identity instead. The
# parent .envrc is loaded first; these `export`s win because direnv
# applies nested .envrc files on top of their parents.
export GIT_AUTHOR_NAME=simlans
export GIT_AUTHOR_EMAIL=55317770+simlans@users.noreply.github.com
export GIT_COMMITTER_NAME=$GIT_AUTHOR_NAME
export GIT_COMMITTER_EMAIL=$GIT_AUTHOR_EMAIL
