# Inherit identity (GIT_AUTHOR_*, GITHUB_USER) from ~/.envrc — direnv
# doesn't walk up by default; without this the flake devShell starts with
# an empty git author.
source_up_if_exists

# Load the flake's devShell so the gitleaks pre-commit hook gets wired
# into `.git/hooks/pre-commit` on first entry. `use flake` runs the
# devShell's shellHook (provided by git-hooks.nix), which is the install
# step for the hook.
use flake

# Pull the user age private key from the 1Password document item
# `op://Private/nixos-sops-keyfile` into SOPS_AGE_KEY, so `sops
# secrets/personal.yaml` works without ~/.config/sops/age/keys.txt
# existing on disk. `op document get` (not `op read`) because the
# 1P item is a Document — that's also why this can't go through
# the existing op-cache wrapper, which only caches field-reference
# reads. direnv only re-runs .envrc on mtime change, so the op call
# happens once per .envrc edit, not per `cd`.
#
# Conditional export: if op fails (typically not signed in), leave
# SOPS_AGE_KEY unset so sops can still fall back to a local key
# file if one is present, instead of erroring on an empty string.
if sops_age_key=$(op document get nixos-sops-keyfile --vault Private 2>/dev/null); then
  export SOPS_AGE_KEY="$sops_age_key"
fi
